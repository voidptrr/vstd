#!/usr/bin/env sh
set -eu

hardening_flags="-O1 -g3 -fno-omit-frame-pointer -fstack-protector-strong -D_FORTIFY_SOURCE=3 -fPIE -fsanitize=address,undefined"
hardening_linker_flags="-Wl,-z,relro,-z,now -pie -fsanitize=address,undefined"

rm -rf build/hardened

cmake \
  -S . \
  -B build/hardened \
  -G Ninja \
  -DCMAKE_BUILD_TYPE=RelWithDebInfo \
  -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
  -DCMAKE_C_FLAGS="$hardening_flags" \
  -DCMAKE_EXE_LINKER_FLAGS="$hardening_linker_flags"

cmake --build build/hardened

run_clang_tidy() {
  status=0
  output="$(clang-tidy --quiet "$@" 2>&1)" || status=$?
  if [ -n "$output" ]; then
    filtered_output="$(printf '%s\n' "$output" |
      sed \
        -e '/^[0-9][0-9]* warnings generated\.$/d' \
        -e '/^Suppressed [0-9][0-9]* warnings/d' \
        -e '/^Use -header-filter=/d')"
    if [ -n "$filtered_output" ]; then
      printf '%s\n' "$filtered_output"
      status=1
    fi
  fi
  if [ "$status" -ne 0 ]; then
    exit "$status"
  fi
}

for file in $(find src -type f -name '*.c' | sort); do
  run_clang_tidy -p build/hardened "$file"
done

for file in $(find include -type f -name '*.h' | sort); do
  run_clang_tidy "$file" -- -Iinclude -std=c17 -x c-header
done

ctest --test-dir build/hardened --output-on-failure
